[sub_resource type="GDScript" id="GDScript_kvpfn"]
resource_name = "menu navigation"
script/source = "extends VBoxContainer
@onready var option1 := $Start
@onready var option2 := $Exit
@onready var selected_choice = 0
@onready var options = [option1,option2]
func _ready()->void:
	option1.grab_focus()
func _process(_detla:float)->void:
	if Input.is_action_just_pressed(\"ui_up\") or Input.is_action_just_pressed(\"ui_down\"):
		selected_choice = 1-selected_choice
		options[selected_choice].grab_focus()
	
"

