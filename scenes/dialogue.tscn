[gd_scene format=3 uid="uid://djneg3xpekyaa"]

[sub_resource type="GDScript" id="GDScript_nfrx5"]
resource_name = "dialogue"
script/source = "extends Control
@onready var text:Label = $diag/Text
@onready var user:Label = $diag/Name
@onready var choicesControl:HBoxContainer = $diag/choices
@onready var choice1:Label=$diag/choices/option1
@onready var choice2:Label=$diag/choices/option2
@onready var currentLine = 0
@onready var txtLines:Array = []
@onready var choices = []
var choosing:=false
var just_opened := false
signal dialogue_closed
func _ready() -> void:
	process_mode = Node.PROCESS_MODE_WHEN_PAUSED
	hide()

func show_dialogue(textLines:Array)->void:
	text.show()
	user.show()
	currentLine = 0
	txtLines = textLines
	get_tree().paused = true
	text.text = txtLines[currentLine]
	just_opened = true
	show()
	await dialogue_closed

func _process(_delta:float)->void:
	if just_opened:
		just_opened = false
		return

	if Input.is_action_just_pressed(\"interact\") and choosing==false:
		if(currentLine >= txtLines.size()-1):
			hide_dialogue()
			currentLine=0
			txtLines=[]
		else:
			currentLine+=1
			text.text=txtLines[currentLine]

func hide_dialogue()->void:
	get_tree().paused=false
	hide()
	dialogue_closed.emit()
func interact(choices:Array)->int:
	choosing=true
	get_tree().paused=true
	show()
	text.hide()
	user.hide()
	choicesControl.show()
	
	
	
	choicesControl.hide()
	choosing=false
	hide()
	return 0
"

